# --- ROS2 stack image and base ---
# Tag of the biba-ros2 service image to pull/run.
BIBA_ROS2_IMAGE_TAG=latest
# Base image used by docker/ros2/Dockerfile (rebuild only).
BIBA_BASE_IMAGE=ghcr.io/goodworkrinkz/biba/biba-ros2-control
BIBA_BASE_TAG=latest

# --- ROS2 / Zenoh ---
ROS_DOMAIN_ID=42
# Set to SUBNET to allow discovery beyond localhost. LOCALHOST keeps the
# stack pinned to the Pi running this compose file.
ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST

# Diff-drive geometry (wheel_separation, wheel_radius, max_wheel_speed)
# is configured in biba_description/urdf/biba.urdf.xacro and
# biba_bringup/config/diff_drive_controller.yaml — not via env.
