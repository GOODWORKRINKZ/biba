<?xml version="1.0"?>
<!--
  BiBa: differential-drive base description.

  Geometry values below are PLACEHOLDERS and must be re-measured against
  the physical robot before relying on TF for navigation. They are
  documented as xacro:property so they can be overridden either by
  editing this file or by passing them as xacro arguments at launch.

  Frames:
    base_footprint  — projection of base_link onto the ground plane
    base_link       — body frame (chassis centroid)
    left_wheel_link / right_wheel_link  — driven wheels (continuous joints)
    imu_link        — STM32-side IMU (BMI160/LSM6DS3)
    stm32_link      — STM32 add-on board (used for sanity / wiring docs)
-->
<robot name="biba" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =================================================================
       Geometry parameters (PLACEHOLDERS — measure on hardware!)
       ================================================================= -->
  <xacro:property name="wheel_separation" value="0.30"/>
  <xacro:property name="wheel_radius"     value="0.0425"/>
  <xacro:property name="wheel_width"      value="0.030"/>
  <xacro:property name="base_length"      value="0.220"/>
  <xacro:property name="base_width"       value="0.180"/>
  <xacro:property name="base_height"      value="0.080"/>
  <!-- Height of base_link origin above the ground (= wheel_radius). -->
  <xacro:property name="base_z_offset"    value="${wheel_radius}"/>

  <!-- Mass placeholders. Inertia tensors are diagonal box approximations. -->
  <xacro:property name="base_mass"        value="2.0"/>
  <xacro:property name="wheel_mass"       value="0.150"/>

  <!-- =================================================================
       Materials
       ================================================================= -->
  <material name="biba_chassis"><color rgba="0.18 0.18 0.20 1.0"/></material>
  <material name="biba_wheel"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="biba_sensor"><color rgba="0.10 0.55 0.85 1.0"/></material>

  <!-- =================================================================
       Reusable macros
       ================================================================= -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (y*y + z*z) / 12.0}" ixy="0.0" ixz="0.0"
        iyy="${m * (x*x + z*z) / 12.0}" iyz="0.0"
        izz="${m * (x*x + y*y) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (3*r*r + h*h) / 12.0}" ixy="0.0" ixz="0.0"
        iyy="${m * (3*r*r + h*h) / 12.0}" iyz="0.0"
        izz="${m * r*r / 2.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="wheel" params="prefix y_sign">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="biba_wheel"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${y_sign * wheel_separation / 2.0} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.05"/>
    </joint>
  </xacro:macro>

  <!-- =================================================================
       Base
       ================================================================= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_z_offset}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="biba_chassis"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <!-- =================================================================
       Wheels
       ================================================================= -->
  <xacro:wheel prefix="left"  y_sign="1"/>
  <xacro:wheel prefix="right" y_sign="-1"/>

  <!-- =================================================================
       Sensor / addon mounts (placeholder transforms)
       ================================================================= -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.020 0.020 0.005"/></geometry>
      <material name="biba_sensor"/>
    </visual>
  </link>
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${base_height/2.0 + 0.005}" rpy="0 0 0"/>
  </joint>

  <link name="stm32_link">
    <visual>
      <geometry><box size="0.060 0.045 0.012"/></geometry>
      <material name="biba_sensor"/>
    </visual>
  </link>
  <joint name="base_to_stm32" type="fixed">
    <parent link="base_link"/>
    <child  link="stm32_link"/>
    <origin xyz="0 0 ${base_height/2.0 + 0.020}" rpy="0 0 0"/>
  </joint>

  <!-- =================================================================
       ros2_control hardware interface (composition C).

       The plugin (biba_hardware_stm32::BibaStm32SystemHardware) owns
       /dev/spidev0.0 and is the sole user of the STM32 wire protocol.
       It exposes velocity command + position/velocity state interfaces
       on the two wheel joints, which diff_drive_controller drives.

       Hardware parameters:
         spi_device       — Linux spidev path
         spi_speed_hz     — SPI clock (1 MHz default; Pi Zero 2W jitter
                            above ~2 MHz is significant)
         max_wheel_speed  — wheel angular velocity (rad/s) corresponding
                            to a normalised setpoint of 1.0; used to
                            convert diff_drive_controller's rad/s output
                            into the STM32's normalised wire format
         wheel_radius     — informational; the controller reads this
                            from its own yaml, kept here for symmetry
       ================================================================= -->
  <ros2_control name="BibaSystem" type="system">
    <hardware>
      <plugin>biba_hardware_stm32/BibaStm32SystemHardware</plugin>
      <param name="spi_device">/dev/spidev0.0</param>
      <param name="spi_speed_hz">1000000</param>
      <param name="wheel_radius">${wheel_radius}</param>
      <param name="max_wheel_speed">20.0</param>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
